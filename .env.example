VK_GROUP_TOKEN=
# Необязательно для vkbottle 4.8+ (оставь для справки / старых инструкций)
VK_GROUP_ID=

OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_API_KEY=

# Google Таблицы: сервисный аккаунт (JSON) + ID из URL таблицы
# Допустимы алиасы: GOOGLE_CREDENTIALS_FILE, GOOGLE_SHEET_ID
GOOGLE_APPLICATION_CREDENTIALS=credentials.json
GOOGLE_SPREADSHEET_ID=
# Необязательно: имя листа; если пусто — первый лист
# GOOGLE_SHEET_WORKSHEET=Лист1

# PROXY=socks5://host:port
